[Container]
ContainerName=cognicode-mcp
Image=cognicode-mcp:latest

# Build from local Dockerfile
# Rebuild: just build-image && systemctl --user restart cognicode-mcp
SetImageCommand=/usr/bin/podman build --tag cognicode-mcp:latest /var/home/rubentxu/Proyectos/rust/CogniCode

# Connect to PostgreSQL container via podman network
# The PG container is accessible as 'cognicode-postgres' on the podman bridge
Environment=DATABASE_URL=postgres://cognicode:cognicode@cognicode-postgres:5432/cognicode
Environment=COGNICODE_PROJECT=/workspace
Environment=RUST_LOG=info

# Mount the project workspace (read-only)
Volume=%h/Proyectos:/workspace:ro

# Expose MCP via stdio (opencode connects via podman exec)
# For network access, also expose the Explorer API
PublishPort=127.0.0.1:3456:8010

# Depends on PostgreSQL being healthy
DependsOn=cognicode-postgres.service

# Auto-restart
[Service]
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
