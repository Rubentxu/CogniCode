# CogniCode — environment variables (example).
#
# Copy to `.env` and adjust as needed:
#   cp .env.example .env
#
# `DATABASE_URL` is read by the cognicode-explorer binaries
# (api, mcp) at startup. `TEST_DATABASE_URL` is read by the PG
# integration tests. Both default to the local docker-compose
# service started with `just dev-pg`.

# Connection string for the cognicode-explorer-api and
# cognicode-explorer-mcp binaries (PG-first default).
DATABASE_URL=postgres://cognicode:cognicode@localhost:5432/cognicode

# Connection string used by the PG integration tests. The tests
# gracefully skip when this is unset (see crates/cognicode-core/tests
# and crates/cognicode-explorer/tests for the skip pattern).
TEST_DATABASE_URL=postgres://cognicode:cognicode@localhost:5432/cognicode

# Target URL the explorer-ui Vite dev server proxies /api/* to.
# Read by apps/explorer-ui/vite.config.ts. Default if unset:
#   http://127.0.0.1:8010
# Override when running the backend in docker-compose or a remote
# host (e.g. EXPLORER_API_TARGET=http://127.0.0.1:8010).
EXPLORER_API_TARGET=http://127.0.0.1:8010
