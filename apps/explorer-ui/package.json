{
  "name": "explorer-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CogniCode Explorer — React 19 + TypeScript + Tailwind 4 frontend for the cognicode-explorer axum backend",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_USE_MOCKS=true vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "build:check-bundle": "node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "cytoscape": "^3.34.0",
    "d3": "^7.9.0",
    "elkjs": "^0.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "swr": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
