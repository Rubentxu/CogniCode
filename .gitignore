.env

# SDD / OpenSpec artifacts (agent planning data)
.tmp-cognicode-verify-extra/
openspec/
sdd/

# SDDK cycle artifacts (workflow state, agent-generated planning data).
# Per user decision (2026-06-24): these are LOCAL ONLY and must never
# be committed. They live next to the repo for developer convenience
# but contain protocol/session state that has no place in git history.
# ADR files (docs/adr/*.md) are EXPLICITLY EXCLUDED — they remain
# tracked because they're first-class project documentation, not
# workflow artifacts.
sddk/
.sddk-last-cycle-complete
.sddk-*

# Proposal documents (agent-generated, not user-requested documentation)
docs/propuestas/
rust-intelligence
sandbox/fixtures/rust-intelligence/
cognicode-*.tar.gz
results/
rust-clippy/
.atl/
specs/
autoresearch/

# Whole `docs/` directory is LOCAL ONLY per user decision (2026-06-24).
# The directory remains on disk for developer reference (ADRs, plans,
# roadmaps, screenshots, etc.) but is not part of the git-tracked
# source. Pre-existing ADR files remain in git history (commits before
# this .gitignore entry was added) — only future commits are affected.
#
# NOTE: The ADRs in docs/adr/ are first-class documentation that the
# project relies on. If you need to commit specific subdirectories of
# docs/ (e.g. ADRs), use `git add -f docs/adr/ADR-NNN-...` to force-add
# despite this ignore rule.
docs/

# Sandbox fixtures: node_modules and build artifacts (not code)
sandbox/fixtures/**/node_modules/
sandbox/fixtures/**/target/
sandbox/fixtures/**/__pycache__/
sandbox/scripts/__pycache__/
*.log
sandbox/fixtures/**/.venv/
sandbox/fixtures/**/venv/
sandbox/fixtures/**/*.lock
sandbox/fixtures/**/package-lock.json
sandbox/fixtures/**/Cargo.lock

# Tier C fixtures are synthetic test data, not source code
sandbox/fixtures/tierc
sandbox/fixtures/tier-c/

# Playwright test artifacts (screenshots, traces, videos from test runs)
# These are generated each test run and should NOT be committed
tests/e2e/report/screenshots/
tests/e2e/report/html/
apps/explorer-ui/test-results/screenshots/
apps/explorer-ui/test-results/traces/
apps/explorer-ui/test-results/videos/
apps/explorer-ui/playwright-report/

# Golden images SHOULD be committed (in __snapshots__/), but temp screenshots not
**/test-results/*.png
**/playwright-report/**/*.png
